# Dockerfile.test — Pre-Built Office Assistant installer test
#
# Tests the install.sh script on a clean Ubuntu 22.04 environment.
# Does NOT test systemd service registration (not available in standard Docker).
# Does NOT test Google Workspace OAuth (no browser).
# Does NOT test Ollama inference (optional — see OLLAMA_MOCK below).
#
# Usage:
#   docker build -f Dockerfile.test -t boa-installer-test .
#   docker run --rm boa-installer-test
#
# To test with a specific install script:
#   docker run --rm -v /path/to/install.sh:/installer/install.sh boa-installer-test

FROM ubuntu:22.04

# Suppress interactive prompts from apt
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=America/Chicago

# Install prerequisites that a typical Ubuntu 22.04 desktop would have
RUN apt-get update && apt-get install -y \
    curl \
    bash \
    sudo \
    ca-certificates \
    git \
    jq \
    lsb-release \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root test user (installer must not require root)
RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER testuser
WORKDIR /home/testuser

# Copy repo into the container so the real installer can run from it.
COPY --chown=testuser:testuser . /home/testuser/installer/

# Installer flags for this Docker smoke lane intentionally skip service install,
# Google setup, and model pulls. This tests packaging/scaffolding, not live auth
# or inference.
ENV INSTALLER_FLAGS="--no-service --skip-google --unattended --skip-model-pull"

RUN cat > /home/testuser/run-test.sh <<'EOF'
#!/bin/bash
set -euo pipefail

WORKSPACE="$HOME/.openclaw/workspace"

pass() {
  echo "[PASS] $1"
}

fail() {
  echo "[FAIL] $1" >&2
  exit 1
}

assert_file() {
  local path="$1"
  [[ -f "$path" ]] && pass "file exists: $path" || fail "missing file: $path"
}

assert_dir() {
  local path="$1"
  [[ -d "$path" ]] && pass "dir exists: $path" || fail "missing dir: $path"
}

echo "[TEST] Installer test environment ready"
echo "[TEST] Running real installer smoke: bash /home/testuser/installer/install.sh $INSTALLER_FLAGS"

bash /home/testuser/installer/install.sh $INSTALLER_FLAGS

echo "[TEST] Verifying installer results"
command -v openclaw >/dev/null 2>&1 && pass "openclaw on PATH" || fail "openclaw missing from PATH"
openclaw --version >/dev/null 2>&1 && pass "openclaw --version works" || fail "openclaw --version failed"

assert_dir "$WORKSPACE"
assert_dir "$WORKSPACE/skills"
assert_dir "$WORKSPACE/documents/drafts"
assert_dir "$WORKSPACE/documents/templates"

assert_file "$WORKSPACE/AGENTS.md"
assert_file "$WORKSPACE/SOUL.md"
assert_file "$WORKSPACE/USER.md"
assert_file "$WORKSPACE/HEARTBEAT.md"
assert_file "$WORKSPACE/MEMORY.md"
assert_file "$WORKSPACE/TOOLS.md"
assert_file "$WORKSPACE/INSTALL-NEXT-STEPS.md"

assert_dir "$WORKSPACE/skills/crm-lite"
assert_dir "$WORKSPACE/skills/document-assistant"
assert_dir "$WORKSPACE/skills/email-assistant"
assert_dir "$WORKSPACE/skills/calendar-assistant"

assert_file "$WORKSPACE/documents/templates/proposal.md"
assert_file "$WORKSPACE/documents/templates/follow-up-email.md"

echo "[TEST] Docker installer smoke completed successfully"
EOF

RUN chmod +x /home/testuser/run-test.sh

CMD ["/home/testuser/run-test.sh"]
