# Dockerfile.test — Pre-Built Office Assistant installer test
#
# Tests the install.sh script on a clean Ubuntu 22.04 environment.
# Does NOT test systemd service registration (not available in standard Docker).
# Does NOT test Google Workspace OAuth (no browser).
# Does NOT test Ollama inference (optional — see OLLAMA_MOCK below).
#
# Usage:
#   docker build -f Dockerfile.test -t boa-installer-test .
#   docker run --rm boa-installer-test
#
# To test with a specific install script:
#   docker run --rm -v /path/to/install.sh:/installer/install.sh boa-installer-test

FROM ubuntu:22.04

# Suppress interactive prompts from apt
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=America/Chicago

# Install prerequisites that a typical Ubuntu 22.04 desktop would have
RUN apt-get update && apt-get install -y \
    curl \
    bash \
    sudo \
    ca-certificates \
    git \
    jq \
    lsb-release \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root test user (installer must not require root)
RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER testuser
WORKDIR /home/testuser

# Installer flags for container environment:
#   --no-service     skip systemd registration
#   --skip-google    skip Google Workspace setup
#   --unattended     non-interactive with defaults
ENV INSTALLER_FLAGS="--no-service --skip-google --unattended"

# Copy installer script (populated when install.sh exists)
# In CI/CD this would be COPY install.sh /home/testuser/install.sh
# For now, create a placeholder that tests the scaffolding
COPY --chown=testuser:testuser . /home/testuser/installer/

# TODO: Replace placeholder with real installer when install.sh is ready
RUN echo "#!/bin/bash" > /home/testuser/run-test.sh && \
    echo "echo '[TEST] Installer test environment ready'" >> /home/testuser/run-test.sh && \
    echo "echo '[TEST] Would run: bash install.sh \$INSTALLER_FLAGS'" >> /home/testuser/run-test.sh && \
    echo "echo '[TEST] Checking prerequisites...'" >> /home/testuser/run-test.sh && \
    echo "which curl && echo '[PASS] curl found' || echo '[FAIL] curl missing'" >> /home/testuser/run-test.sh && \
    echo "which bash && echo '[PASS] bash found' || echo '[FAIL] bash missing'" >> /home/testuser/run-test.sh && \
    echo "which git  && echo '[PASS] git found'  || echo '[FAIL] git missing'"  >> /home/testuser/run-test.sh && \
    echo "echo '[TEST] Prerequisite check complete'" >> /home/testuser/run-test.sh && \
    chmod +x /home/testuser/run-test.sh

CMD ["/home/testuser/run-test.sh"]

